  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Cultivar alimentos tamb\xE9m ajuda a ter comida fresca em casa. Frutas,
    legumes e ervas acabados de colher podem ser usados em saladas, sopas, sandes,
    pratos cozinhados ou lanches saud\xE1veis. Al\xE9m disso, mexer na terra, cuidar
    das plantas e passar tempo ao ar livre tamb\xE9m pode fazer bem ao corpo e \xE0
    ment\n\nMas n\xE3o \xE9 preciso ter um grande jardim para cultivar alimentos.
    Quem vive num apartamento pode usar uma varanda, uma janela com sol ou vasos
    pequenos. Em vasos, \xE9 poss\xEDvel plantar ervas arom\xE1ticas, alface, tomate-cereja,
    morangos, rabanetes ou outros vegetais pequenos."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}
  m_sharedMaterial: {fileID: 4175271790479028392, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}

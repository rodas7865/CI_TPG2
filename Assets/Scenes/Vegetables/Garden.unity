  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Ter uma horta em casa pode ajudar as crian\xE7as a gostar mais de frutas
    e vegetais, porque \xE9 especial comer algo que n\xF3s pr\xF3prios ajud\xE1mos
    a cuidar. Regar, observar as folhas, ver as flores aparecerem e colher os alimentos
    torna a comida mais interessante e divertida."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}
  m_sharedMaterial: {fileID: 4175271790479028392, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}

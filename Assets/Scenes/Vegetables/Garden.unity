  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Cultivar frutas e vegetais ensina <b>paci\xEAncia</b>, <b>responsabilidade</b>
    e <b>respeito pela natureza</b>. Nem tudo cresce num instante, e est\xE1 tudo
    bem! As melhores coisas precisam de tempo. E no fim, comer algo que cresceu com
    a nossa ajuda torna a refei\xE7\xE3o ainda mais especial. <size=125%><b><color=green>Agora,
    m\xE3os \xE0 terra e sorriso no rosto!</color></b></size> \n\n\n<size=115%><b><color=#8B4513>O
    Senhor T\xF3 Batata diz: cuidar de uma planta \xE9 plantar um bocadinho de alegria!</color></b></size>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}
  m_sharedMaterial: {fileID: 4175271790479028392, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}

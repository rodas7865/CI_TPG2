  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Uma <b><color=#00BFFF>varanda</color></b>, uma janela com sol ou alguns
    vasos pequenos j\xE1 podem ser o in\xEDcio de uma mini-horta. Em vasos, podemos
    plantar <b>ervas arom\xE1ticas</b>, <b>alface</b>, <b>tomate-cereja</b>, <b>morangos</b>,
    <b>rabanetes</b> ou outros vegetais pequenos. Para uma horta na varanda, h\xE1
    uns truques de agricultor que ajudam muito: escolher <b>vasos com furos</b> para
    a \xE1gua sair, usar <b>boa terra</b>, colocar as plantas num s\xEDtio com <b>luz</b>
    e regar com cuidado. As plantas precisam de <b><color=#00BFFF>\xE1gua</color></b>,
    <b><color=yellow>sol</color></b> e <b><color=green>aten\xE7\xE3o</color></b>,
    tal como n\xF3s precisamos de comida, descanso e carinho. \n\n\n<size=120%><b><color=#8B4513>Palavra
    de batata: plantas felizes d\xE3o pratos mais felizes!</color></b></size>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}

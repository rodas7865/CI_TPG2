  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Quando plantamos frutas e vegetais no jardim, aprendemos de onde vem a
    comida. Uma <b><color=green>alface</color></b>, um <b><color=red>tomateiro</color></b>,
    uns <b><color=#FF3366>morangos</color></b> ou umas <b><color=green>ervas arom\xE1ticas</color></b>
    n\xE3o aparecem por magia no prato. \n\nPrimeiro crescem devagarinho, com terra,
    \xE1gua, sol e paci\xEAncia.\n\n\n<size=120%><b><color=#8B4513>Hmmm... cheirinho
    a terra boa!</color></b></size> \n\n\n\n\n\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}
  m_sharedMaterial: {fileID: 4175271790479028392, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}

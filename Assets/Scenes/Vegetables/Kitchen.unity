  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Mas cuidado! Um bom cozinheiro n\xE3o exagera no <b>sal</b>, no <b>a\xE7\xFAcar</b>
    nem na <b>gordura</b>. A comida pode ficar deliciosa com <color=green>ervas</color>,
    <color=#F5DEB3>alho</color>, <color=#DAA520>cebola</color>, <color=yellow>lim\xE3o</color>
    ou especiarias suaves.\n\n <size=115%><b><color=orange>Na minha cozinha, sabor
    n\xE3o precisa de exageros!</color></b></size>\n\n\n Cozinhar em casa tamb\xE9m
    \xE9 uma \xF3tima ideia, porque podemos escolher melhor o que vai para o prato.
    Podemos usar mais <b><color=green>legumes</color></b>, <b><color=red>frutas</color></b>,
    <b>cereais integrais</b>, <b>feij\xE3o</b>, <b>peixe</b>, <b>ovos</b> ou <b>carnes
    magras</b>. E sabem outra coisa? Quando cozinhamos em casa, podemos evitar muitas
    comidas muito processadas, que \xE0s vezes t\xEAm sal, a\xE7\xFAcar e gorduras
    a mais escondidos. Hmph! O Chef R\xFAben fica de olho nisso!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}
  m_sharedMaterial: {fileID: 4175271790479028392, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}

      m_Calls: []
  m_text: "<size=130%><b><color=#FF3366>Bom dia, pequenos cozinheiros! Eu sou o Chef
    R\xFAben Rabanete!</color></b></size>\n\n Aten\xE7\xE3o, aten\xE7\xE3o! Panelas
    prontas? Colheres no ar? Aventais apertados? Eu sou o <b><color=#FF3366>Chef
    R\xFAben Rabanete</color></b>, o rabanete mais r\xE1pido, crocante e mand\xE3o
    da cozinha! Hoje vou ensinar-vos uma coisa muito importante: <b><color=orange>cozinhar
    bem ajuda o corpo a crescer saud\xE1vel</color></b>! Cozinhar n\xE3o \xE9 s\xF3
    p\xF4r comida numa panela e esperar. Nada disso! Cozinhar \xE9 preparar os alimentos
    para ficarem <b>seguros</b>, <b>saborosos</b> e bons para o nosso corpo."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}

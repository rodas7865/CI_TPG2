  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "O iogurte \xE9 feito a partir de leite, que \xE9 aquecido e depois recebe
    bact\xE9rias espec\xEDficas. Estas bact\xE9rias transformam parte do a\xE7\xFAcar
    do leite em \xE1cido l\xE1ctico, fazendo com que o leite fique mais espesso.
    Depois de algumas horas de fermenta\xE7\xE3o, o iogurte est\xE1 pronto para ser
    consumido."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}

  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Quando bebes estas bebidas, o teu corpo recebe um pico gigante e imediato,
    parece um foguet\xE3o a subir ao espa\xE7o! No entanto, esse combust\xEDvel artificial
    acaba num piscar de olhos e o teu foguet\xE3o cai a pique. De repente, vais sentir-te
    muito cansado, sem for\xE7as para correr e com uma valente dor de cabe\xE7a. "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}

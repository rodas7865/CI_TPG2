  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Pronto para descolar? Eu sou o <b>Brocollino</b> e guio-te pelo incr\xEDvel
    imp\xE9rio dos Vegetais! N\xF3s somos os verdadeiros defensores verdes da Terra,
    cheios de vitaminas secretas que mant\xEAm o teu corpo leve, ultra r\xE1pido
    e forte. Prepara-te para ligar os motores e aprender a salvar a nossa comida
    do \xF3leo pesado das <b>Batatas Fritas</b>!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}
  m_sharedMaterial: {fileID: 4175271790479028392, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}

  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Viva! Eu sou a <b>Moranguita</b> e dou-te as boas-vindas ao mundo perfumado
    e delicioso das Frutas! A Natureza deu-nos os doces mais saborosos, coloridos
    e saud\xE1veis para nos dar boa energia. Est\xE1s pronto para te juntares \xE0
    minha equipa e ajudar-me a defender o nosso reino saud\xE1vel contra o ex\xE9rcito
    dos <b>Donuts</b>?"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}
  m_sharedMaterial: {fileID: 4175271790479028392, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}

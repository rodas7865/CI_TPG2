  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Estes doces adoram organizar uma festa maluca e barulhenta no meio dos
    teus dentes. Se eles ficarem l\xE1 a dormir muito tempo, convidam os terr\xEDveis
    \"bichinhos do a\xE7\xFAcar\" para irem l\xE1 morar. Estes bichinhos escavam
    buracos chamados c\xE1ries que deixam os teus dentes muito fracos e causam dores
    bastante chatas!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}
  m_sharedMaterial: {fileID: 4175271790479028392, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}

  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<i>Rica em prote\xEDnas de alta qualidade</i>: Cont\xE9m todos os amino\xE1cidos
    essenciais, como a lisina e a leucina, que ajudam a construir e reparar os m\xFAsculos,
    fundamental para o crescimento das crian\xE7as.\n\n<i>Baixa em gordura saturada</i>:
    Tem menos gordura do que outras carnes, o que a torna uma op\xE7\xE3o mais saud\xE1vel
    para o cora\xE7\xE3o e para manter um peso equilibrado.\n\n<i>F\xE1cil de digerir</i>:
    As suas prote\xEDnas s\xE3o de digest\xE3o r\xE1pida, ideal para crian\xE7as
    e pessoas que precisam de uma alimenta\xE7\xE3o leve e nutritiva.\n"

  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "A carne vermelha \xE9 um alimento poderoso, cheio de nutrientes que ajudam
    a manter o corpo forte e cheio de energia. Ela vem de animais como a vaca, o
    porco e o cordeiro, e \xE9 uma das principais fontes de ferro, um mineral superimportante
    que ajuda a transportar oxig\xE9nio no sangue. Sem ferro, sentir\xEDamos cansa\xE7o
    e fraqueza.\nPor que \xE9 especial?\n\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6110c3e5dc1ef554583c910e6c2a637f, type: 2}
